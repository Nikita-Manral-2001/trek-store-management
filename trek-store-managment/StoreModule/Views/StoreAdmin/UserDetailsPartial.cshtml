@model TTH.Areas.Super.Models.TrekkersStore.AdminOrderDetailsViewModel

<div class="p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5><strong>OrderId:</strong> @Model.Orders.Id</h5>
        <h5><strong>Status:</strong> <span class="text-danger">@Model.OrderItems.FirstOrDefault()?.Status</span></h5>
    </div>
    <div class="mb-3">
        <h6>Billing details</h6>
        @if (Model.Address != null)
        {
            <p>
                @Model.Address.FirstName @Model.Address.LastName <br />
                @Model.Address.StreetAddress<br />
                @Model.Address.City @Model.Address.PinCode <br />
                @Model.Address.State
            </p>
            <p><strong>Email:</strong> @Model.Address.Email</p>
            <p><strong>Phone:</strong> @Model.Address.PhoneNo</p>
        }
        else
        {
            <p class="text-muted">No billing details available</p>
        }
    </div>

    <div class="mb-3">
        <h6>Product</h6>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Size</th>
                    <th>Color</th>
                    <th>Quantity</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderItems)
                {
                    <tr>
                        <td>
                            <img src="@Url.Content("~/" + item.ImagePath.TrimStart('/'))"
                                 alt="Product Image" width="80"  height="80"   />
                        </td>
                        <td>@item.ProductName</td>
                        <td>@item.SizeName</td>
                        <td>@item.ColorName</td>
                        <td>@item.Quantity</td>
                        <td>₹@item.PricePerDay</td>
                    </tr>
                }
                <tr>
                  
                    <td colspan="5" class="text-end"><strong>Total :</strong></td>
                    <td colspan="1"><strong>₹@Model.OrderItems.Sum(x => x.Quantity * x.PricePerDay)</strong></td>

                </tr>
            </tbody>
        </table>
    </div>
</div>

