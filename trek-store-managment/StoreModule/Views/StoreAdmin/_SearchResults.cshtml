@model List<TTH.Areas.Super.Models.TrekkersStore.OrderDetailsViewModel>

<style>
    .rent-export-container {
        display: flex;
        justify-content: flex-end; /* Aligns content to the right */
        margin-top: -40px; /* Keep if needed for spacing */
    }

    .RentExportbtn {
        /* You can style the button as needed here */
        padding: 8px 16px;
        cursor: pointer;
    }
</style>
<div>
    <form id="exportForm" method="post" asp-area="Super" asp-action="ExportExcelData" asp-controller="RentAdmin">
        <input type="hidden" name="orderIds" id="orderIds" />
        <div class="rent-export-container">
            <button type="button" class="btn btn-primary RentExportbtn" onclick="prepareExport()">Export Data</button> <!-- Change type to button -->
        </div>
        @foreach (var group in Model.GroupBy(x => new { x.UserId,x.BookingId }))
        {
            <input type="hidden" class="order-id" value="@group.First().Id" />
        }
    </form>
    <table class="table table-bordered">
        <thead class="thead-light">
            <tr>

                 <th>User Details</th>
                <th>Order Date</th>
                <th>Status</th>
                <th>Payment</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in Model.GroupBy(x => new { x.UserId,x.BookingId }))
            {
                <tr>

                    <td>
                        <a asp-controller="StoreAdmin"
                           asp-action="UserProductDetails"
                           asp-route-bookingId="@group.First().BookingId">
                            @group.First().Id  @group.First().FirstName @group.First().LastName
                        </a>

                       

                        <i class="fas fa-eye"
                           data-bs-toggle="modal"
                           data-bs-target="#viewModal"
                           data-bookingid="@group.First().BookingId"
                           style="cursor:pointer;">
                        </i>
                        <!-- Modal -->
                        <div class="modal fade" id="viewModal" tabindex="-1" aria-labelledby="viewModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-lg">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="viewModalLabel">View Details</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                    </div>
                                    <div class="modal-body" id="modalContent">
                                        <p>Details about the product/record will appear here.</p>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </td>

                    <td class="text-success">@group.First().Status</td>
                    <td>
                          @if (group.First().PaymentStatus == "Paid")
                        {
                            <strong>OrderDate:</strong> @group.First().OrderDate.ToString("dd MMM yyyy")

                            
                            

                            
                        }
                    </td>
                    <td>
                           <strong>Paid Amount:</strong>@group.Sum(x => x.Amount).ToString()<br> 

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function prepareExport() {
        let orderIds = [];
        document.querySelectorAll('.order-id').forEach(input => {
            orderIds.push(input.value);
        });

        document.getElementById('orderIds').value = orderIds.join(',');
        document.getElementById('exportForm').submit(); // Submit the form after setting the value
    }
</script>
<script>
    var viewModal = document.getElementById('viewModal');
    viewModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget; // The eye icon
        var bookingId = button.getAttribute('data-bookingid');
        var modalBody = document.getElementById('modalContent');

        modalBody.innerHTML = "<p>Loading...</p>";


        $.ajax({
            url: "/Super/StoreAdmin/GetUserDetails/" + bookingId,
            type: 'GET',
            data: { bookingId: bookingId },
            success: function (data) {
                modalBody.innerHTML = data;
            },
            error: function () {
                modalBody.innerHTML = "<p class='text-danger'>Error loading data.</p>";
            }
        });
    });
</script>
